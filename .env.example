# ====================================
# DISCORD CONFIGURATION
# ====================================

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord application/bot client ID
DISCORD_CLIENT_ID=your_discord_application_id_here

# Your Discord guild (server) ID where the bot will be installed
DISCORD_GUILD_ID=your_discord_guild_id_here

# ====================================
# DATABASE CONFIGURATION
# ====================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Default database name: cusarbot
# Default user: cusarbot
DATABASE_URL=postgresql://cusarbot:your_secure_password_here@localhost:5432/cusarbot

# ====================================
# ROBLOX CONFIGURATION
# ====================================

# Roblox .ROBLOSECURITY Cookie
# Get this from your browser: F12 > Application > Cookies > .ROBLOSECURITY
# IMPORTANT: This will be encrypted before storage
ROBLOX_COOKIE=your_roblosecurity_cookie_here

# Primary Roblox group ID (the main group your community uses)
PRIMARY_GROUP_ID=your_roblox_group_id_here

# ====================================
# SECURITY
# ====================================

# 32-character encryption key for sensitive data (Roblox cookies)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64').slice(0,32))"
ENCRYPTION_KEY=generate_a_32_character_random_string

# API key for Roblox game -> bot communication
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_KEY=generate_a_long_random_api_key

# ====================================
# SERVER CONFIGURATION
# ====================================

# Port for the API server
PORT=3000

# Environment: development | production
NODE_ENV=production
